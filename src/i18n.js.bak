i18n.use(initReactI18next).init({
  resources,
  fallbackLng: "en",
  lng:
    localStorage.getItem("language") ||
    (navigator.language.startsWith("fr")
      ? "fr"
      : navigator.language.startsWith("ar")
        ? "ar"
        : "en"),
  interpolation: { escapeValue: false },
});

export default i18n;


